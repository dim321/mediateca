# Secrets for Kamal deploy. Kamal loads this file with Ruby Dotenv.parse (see gem kamal), not via bash source.
# Use KEY=value lines; $(...) command substitution is supported by Kamal's dotenv extension.
# Export vars in your shell or `.env` before deploy so ${VAR} substitutions resolve. Do not commit real secrets.

# Yandex Container Registry: OAuth token or pusher account password.
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}

# Rails master key.
RAILS_MASTER_KEY=$(cat config/master.key)

# DB user password (app + Postgres). Set MEDIATECA_DATABASE_PASSWORD before deploy, e.g. in .env (not committed).
MEDIATECA_DATABASE_PASSWORD=${MEDIATECA_DATABASE_PASSWORD}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-$MEDIATECA_DATABASE_PASSWORD}

# Yandex Object Storage (Active Storage). Must be non-empty before deploy — validated by .kamal/hooks/pre-deploy.
# See .env.deploy.example.
YC_ACCESS_KEY_ID=${YC_ACCESS_KEY_ID}
YC_SECRET_ACCESS_KEY=${YC_SECRET_ACCESS_KEY}
