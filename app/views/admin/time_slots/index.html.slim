div class="mb-6"
  = link_to "← #{@device.name}", admin_device_path(@device), class: "text-sm text-indigo-600 hover:text-indigo-500"

div class="flex justify-between items-center mb-6"
  h1 class="text-2xl font-bold text-gray-900"
    | #{t("admin.time_slots.index.title")}: #{@device.name}
  div class="flex items-center space-x-3"
    = form_with url: admin_device_time_slots_path(@device), method: :get, class: "flex items-center space-x-2", data: { turbo_frame: "_top" } do |f|
      = f.date_field :date, value: @date, class: "rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border"
      = f.submit t("admin.time_slots.index.show"), class: "px-3 py-2 bg-gray-100 text-sm font-medium rounded-md hover:bg-gray-200 cursor-pointer"

    = form_with url: generate_admin_device_time_slots_path(@device), method: :post, class: "inline-flex items-center" do |f|
      = hidden_field_tag :date, @date.strftime("%Y-%m-%d")
      = f.submit t("admin.time_slots.index.generate"), class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 cursor-pointer"

- if @time_slots.any?
  div class="bg-white shadow overflow-hidden rounded-lg"
    table class="min-w-full divide-y divide-gray-200"
      thead class="bg-gray-50"
        tr
          th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase" = t("admin.time_slots.index.time")
          th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase" = t("admin.time_slots.index.status")
          th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase" = t("admin.time_slots.index.price")
          th class="px-6 py-3"
      tbody class="bg-white divide-y divide-gray-200"
        - @time_slots.each do |slot|
          = render "time_slot", slot: slot
- else
  div class="bg-white shadow rounded-lg p-8 text-center"
    p class="text-gray-500" = t("admin.time_slots.index.empty", date: l(@date, format: :long))
    p class="text-sm text-gray-400 mt-1" = t("admin.time_slots.index.empty_hint")
