<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Группы устройств</h1>
  <%= link_to "Создать группу", new_admin_device_group_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
</div>

<% if @groups.any? %>
  <div class="bg-white shadow overflow-hidden rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Название</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Устройств</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @groups.each do |group| %>
          <tr>
            <td class="px-6 py-4">
              <%= link_to group.name, admin_device_group_path(group), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              <% if group.description.present? %>
                <p class="text-xs text-gray-400 mt-1"><%= group.description %></p>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= group.devices_count %></td>
            <td class="px-6 py-4 text-right text-sm">
              <%= link_to "Изменить", edit_admin_device_group_path(group), class: "text-gray-600 hover:text-gray-900 mr-3" %>
              <%= button_to "Удалить", admin_device_group_path(group), method: :delete, class: "text-red-600 hover:text-red-900", data: { turbo_confirm: "Удалить группу?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-white shadow rounded-lg p-8 text-center">
    <p class="text-gray-500">Нет групп устройств.</p>
  </div>
<% end %>
