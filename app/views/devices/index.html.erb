<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Устройства</h1>
  <p class="text-sm text-gray-500 mt-1">Выберите устройство для просмотра расписания и планирования трансляций</p>
</div>

<%= form_with url: devices_path, method: :get, class: "mb-6 flex items-center space-x-3" do |f| %>
  <%= f.text_field :city, value: params[:city], placeholder: "Фильтр по городу", class: "rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
  <%= f.submit "Фильтр", class: "px-4 py-2 bg-gray-100 text-sm font-medium rounded-md hover:bg-gray-200 cursor-pointer" %>
  <% if params[:city].present? %>
    <%= link_to "Сбросить", devices_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <% end %>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @devices.each do |device| %>
    <div class="bg-white shadow rounded-lg p-5">
      <div class="flex justify-between items-start">
        <div>
          <h3 class="text-lg font-semibold text-gray-900"><%= device.name %></h3>
          <p class="text-sm text-gray-500"><%= device.city %>, <%= device.address %></p>
        </div>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          Online
        </span>
      </div>
      <div class="mt-4">
        <%= link_to "Расписание", schedule_device_path(device), class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
      </div>
    </div>
  <% end %>
</div>

<% if @devices.empty? %>
  <div class="bg-white shadow rounded-lg p-8 text-center">
    <p class="text-gray-500">Нет доступных устройств.</p>
  </div>
<% end %>
